{
  "expo": {
    "name": "Inventory Scanner",
    "slug": "inventory-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "inventory-scanner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.replit.inventoryscanner",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan product barcodes.",
        "NSPhotoLibraryUsageDescription": "This app saves CSV exports to your device."
      }
    },
    "android": {
      "package": "com.replit.inventoryscanner",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Inventory Scanner to access your camera so you can scan product barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "46cb6f08-5f51-4ea0-979b-ca48b893cdf0"
      }
    }
  }
}
